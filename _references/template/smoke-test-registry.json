{
  "$schema": "smoke-test-registry-v1",
  "_comment": "Template smoke test registry. Generated by /quickstart step 10.2. Edit endpoints to match your API.",
  "framework": "{{backend.framework}}",
  "test_config": "{{test_config}}",
  "auth": {
    "method": "{{backend.auth}}",
    "user_model_path": "{{auth.user_model_path}}",
    "user_model_login_field": "login",
    "register_path": "/api/auth/register",
    "login_path": "/api/auth/login",
    "profile_path": "/api/auth/profile",
    "register_body": {
      "login": "smoke_user",
      "email": "smoke@test.local",
      "name": "Smoke Test User",
      "password": "Sm0keP@ss!"
    },
    "login_body": {
      "login": "smoke_user",
      "password": "Sm0keP@ss!"
    },
    "admin_register_body": {
      "login": "smoke_admin",
      "email": "smoke_admin@test.local",
      "name": "Smoke Admin",
      "password": "Adm1nP@ss!"
    },
    "admin_role_field": "role",
    "admin_role_value": 99
  },
  "groups": [
    {
      "_comment": "Example CRUD group — replace with your domain entities",
      "name": "Example Entity",
      "endpoints": [
        {
          "method": "POST",
          "path": "/api/examples",
          "body": { "name": "Smoke Test Example" },
          "expect": [201],
          "auth": true,
          "capture_id": true,
          "label": "create"
        },
        {
          "method": "GET",
          "path": "/api/examples",
          "expect": [200],
          "auth": true,
          "label": "list"
        },
        {
          "method": "GET",
          "path": "/api/examples/{id}",
          "expect": [200],
          "auth": true,
          "label": "detail"
        },
        {
          "method": "PUT",
          "path": "/api/examples/{id}",
          "body": { "name": "Updated Example" },
          "expect": [200],
          "auth": true,
          "label": "update"
        },
        {
          "method": "DELETE",
          "path": "/api/examples/{id}",
          "expect": [200, 204],
          "auth": true,
          "label": "delete"
        }
      ]
    }
  ],
  "destructive_auth": [
    {
      "method": "POST",
      "path": "/api/auth/logout",
      "expect": [200],
      "auth": true,
      "label": "logout"
    }
  ]
}
